---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LeaderboardTable from "../../components/LeaderboardTable.astro";
import ResultsTable from "../../components/ResultsTable.astro";
import { getAllTimeSummary, getTableRows } from "../../data/doppelkopf";

const summary = getAllTimeSummary();
const rows = getTableRows([...summary.matches].reverse(), false);
---

<BaseLayout title="Ewige Tabelle | JACK Arena">
  <section class="hero compact">
    <div class="shell flow">
      <p class="eyebrow">Doppelkopf</p>
      <h1>Ewige Tabelle</h1>
    </div>
  </section>

  <section class="section">
    <div class="shell flow">
      <div class="section-heading">
        <h2>Tabelle</h2>
      </div>
      <LeaderboardTable entries={summary.leaderboard} />
    </div>
  </section>

  <section class="section">
    <div class="shell flow">
      <div class="section-heading">
        <h2>Ergebnisse</h2>
      </div>
      <ResultsTable rows={rows} />
    </div>
  </section>
</BaseLayout>
