---
import { seasons } from "../data/doppelkopf";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "JACK Arena Doppelkopf archive and standings." } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f1722" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="shell header-inner">
        <nav class="site-nav" aria-label="Primary">
          <a class="site-brand" href="/">JACK ARENA</a>
          <details class="nav-group">
            <summary>Doppelkopf</summary>
            <div class="nav-panel">
              <details class="nav-subgroup">
                <summary>Meisterschaften</summary>
                <div class="nav-subpanel">
                  {seasons.map((season) => (
                    <a href={`/doppelkopf/${season}/`}>{season}</a>
                  ))}
                </div>
              </details>
              <a href="/doppelkopf/all-time-stats/">Ewige Tabelle</a>
              <a href="/doppelkopf/statistiken/">Statistiken</a>
              <a href="/doppelkopf/seating/">Sitzreihenfolgen</a>
            </div>
          </details>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
